# Patrimoine Desktop — Environment Variables
#
# Copy this file to .env and fill in your values.
# The app works without these variables (defaults to local SQLite).

# ── Optional: Turso / libsql remote database ────────────────────────────────
# Leave empty to use local SQLite (default).
# Set both to enable encrypted remote replica via libsql.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
